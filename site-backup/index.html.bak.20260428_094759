<script>
function toggleValue(btn) {
  var body = btn.nextElementSibling;
  var icon = btn.querySelector('.value-icon');
  var isOpen = body.style.display === 'block';
  body.style.display = isOpen ? 'none' : 'block';
  if (icon) icon.textContent = isOpen ? '+' : '−';
}

document.getElementById('supportForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    
    const submitBtn = document.getElementById('supportSubmitBtn');
    const messageDiv = document.getElementById('supportStatusMsg');
    
    // Disable button and show loading
    submitBtn.textContent = 'Submitting...';
    submitBtn.disabled = true;
    
    const formData = {
        name: document.getElementById('supportName').value,
        email: document.getElementById('supportEmail').value,
        issue_type: document.getElementById('supportType').value,
        message: document.getElementById('supportMessage').value,
        urgency: document.getElementById('supportUrgency').value,
        timestamp: new Date().toISOString(),
        page: 'index.html'
    };
    
    try {
        // Submit to our Flask backend (to be built next)
        const response = await fetch('/api/support-ticket', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify(formData)
        });
        
        if (response.ok) {
            messageDiv.style.display = 'block';
            messageDiv.style.color = '#10b981';
            messageDiv.textContent = '✅ Support ticket submitted successfully! We\'ll get back to you within 24 hours.';
            document.getElementById('supportForm').reset();
        } else {
            throw new Error('Server error');
        }
    } catch (error) {
        messageDiv.style.display = 'block';
        messageDiv.style.color = '#ef4444';
        messageDiv.textContent = '❌ Error submitting ticket. Please try again or email us directly.';
    }
    
    // Reset button
    submitBtn.textContent = 'Submit Support Ticket';
    submitBtn.disabled = false;
});
</script>


