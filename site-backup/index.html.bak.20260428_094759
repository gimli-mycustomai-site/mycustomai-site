<script>
// Load live testimonials from testimonials.json — replace placeholders when real data exists
(function() {
  fetch('/testimonials.json?v=' + Date.now())
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (!Array.isArray(data) || data.length === 0) return; // keep placeholders
      var grid = document.getElementById('testimonialsGrid');
      var note = document.getElementById('testimonialsNote');
      if (!grid) return;
      // Remove placeholder cards
      grid.querySelectorAll('.placeholder-card').forEach(function(c) { c.remove(); });
      // Render real testimonials
      data.forEach(function(t) {
        var stars = '★'.repeat(Math.min(5, parseInt(t.rating) || 5));
        var initials = (t.name || '?').split(' ').map(function(w){return w[0];}).join('').slice(0,2).toUpperCase();
        var card = document.createElement('div');
        card.className = 'testimonial-card';
        card.innerHTML =
          '<div class="testimonial-stars">' + stars + '</div>' +
          '<p class="testimonial-quote">"' + t.testimonial.replace(/"/g, '&quot;') + '"</p>' +
          '<div class="testimonial-author">' +
            '<div class="testimonial-avatar">' + initials + '</div>' +
            '<div>' +
              '<div class="testimonial-name">' + t.name + '</div>' +
              '<div class="testimonial-title">' + (t.title || '') + '</div>' +
            '</div>' +
          '</div>';
        grid.appendChild(card);
      });
      if (note) note.style.display = 'none'; // hide disclaimer when real data loads
    })
    .catch(function() {}); // silently keep placeholders on error
})();
</script>

