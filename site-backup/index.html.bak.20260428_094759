async function submitInterestForm(e) {
  e.preventDefault();
  var form = document.getElementById('interestForm');
  var btn = document.getElementById('interestSubmitBtn');
  var errEl = document.getElementById('interestError');
  errEl.style.display = 'none';
  btn.disabled = true;
  btn.textContent = 'Submitting…';

  var data = {
    name: form.name.value.trim(),
    email: form.email.value.trim(),
    tier: form.tier.value,
    timeline: form.timeline.value
  };

  try {
    var res = await fetch('https://mycustomai-backend-1.onrender.com/api/interest-list', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data)
    });
    if (!res.ok) throw new Error('Server error ' + res.status);
    document.getElementById('interestForm').style.display = 'none';
    document.getElementById('interestSuccess').style.display = 'block';
  } catch(err) {
    // Graceful fallback: mailto
    var subject = encodeURIComponent('Interest List: ' + data.tier);
    var body = encodeURIComponent(
      'Name: ' + data.name + '\n' +
      'Email: ' + data.email + '\n' +
      'Tier: ' + data.tier + '\n' +
      'Timeline: ' + data.timeline
    );
    errEl.innerHTML = 'Could not reach our server. <a href="mailto:support@mycustomai.co?subject=' + subject + '&body=' + body + '" style="color:#d4a843;">Click here to email us instead</a>.';
    errEl.style.display = 'block';
    btn.disabled = false;
    btn.textContent = 'Join the Interest List';
  }
}
